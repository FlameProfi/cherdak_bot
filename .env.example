# Telegram Bot Settings
BOT_TOKEN=your_telegram_bot_token
ADMIN_TG_ID=123456789

# Fusion POS Settings
FUSION_API_KEY=your_fusion_pos_api_token
FUSION_DOMAIN=your_subdomain
FUSION_API_VERSION=v4
# Optional: ID группы для новых клиентов (требуется для v2)
FUSION_DEFAULT_GROUP_ID=1
# Optional: override base URL
FUSION_BASE_URL=

# Server Settings
PORT=3000
WEBHOOK_SECRET=some_random_secret_for_fusion_webhooks

# External Links
MENU_URL=https://example.com/menu
BOOKING_URL=https://example.com/book
REVIEW_URL=https://example.com/review
